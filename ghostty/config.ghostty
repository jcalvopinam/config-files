#This file was created from $HOME/Library/Application Support/com.mitchellh.ghostty/config
#docs: https://ghostty.org/docs/config
#Run `ghostty +show-config --default --docs` to view a list of options

#-------------------------------------------------------------
# General
#-------------------------------------------------------------
theme = "light:fancylight,dark:fancydracula"
macos-titlebar-style = tabs
unfocused-split-opacity = 0.7
confirm-close-surface = true
macos-option-as-alt = left
minimum-contrast = 1.5

#-------------------------------------------------------------
# Font
#-------------------------------------------------------------
#font-family = "MesloLGS NF"
font-family = Iosevka
font-size = 16
font-thicken = false

#-------------------------------------------------------------
# Window
#-------------------------------------------------------------
window-width = 164
window-height = 50
window-padding-x = 20
window-padding-y = 20
window-decoration = true
window-step-resize = false
# window-background-opacity = 0.95
# window-background-blur = true

#-------------------------------------------------------------
# Cursor
#-------------------------------------------------------------
cursor-style = block
cursor-style-blink = true
cursor-invert-fg-bg = true

#-------------------------------------------------------------
# Shortcuts
#-------------------------------------------------------------
keybind = cmd+enter=new_split:down
keybind = cmd+shift+enter=new_split:right
keybind = alt+cmd+enter=toggle_split_zoom
keybind = alt+cmd+left=goto_split:left
keybind = alt+cmd+right=goto_split:right
keybind = alt+cmd+up=goto_split:up
keybind = alt+cmd+down=goto_split:down
keybind = alt+cmd+shift+left=resize_split:left,10
keybind = alt+cmd+shift+right=resize_split:right,10
keybind = alt+cmd+shift+up=resize_split:up,10
keybind = alt+cmd+shift+down=resize_split:down,10
