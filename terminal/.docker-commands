#----------------------------------------------------------------------------------
# list the container IP
#----------------------------------------------------------------------------------
function dip {
  local actcont=$(docker ps --format "{{.Names}}")
  for DOC in $actcont; do
    IP=$(docker inspect --format='{{range .NetworkSettings.Networks}}{{.IPAddress}} {{end}}' "$DOC")
    OUT+=$DOC'\t'$IP'\n'
  done
  echo -e $OUT | column -t
  unset OUT
}

#----------------------------------------------------------------------------------
# removes all dangling Docker images (unused images taking up space)
#----------------------------------------------------------------------------------
function dirma {
  imgs=$(docker images -q -f dangling=true)
  [[ -n "$imgs" ]] && echo "$imgs" | xargs docker rmi || echo "No dangling images found."

}

#----------------------------------------------------------------------------------
# removes all dangling Docker volumes (unused volumes taking up space)
#----------------------------------------------------------------------------------
function dvrma {
  vols=$(docker volume ls -qf dangling=true)
  [[ -n "$vols" ]] && echo "$vols" | xargs docker volume rm || echo "no dangling volumes."
}

#----------------------------------------------------------------------------------
# docker ls by atributes. e.g.: dls net | dls ports | dls size
#----------------------------------------------------------------------------------
function dls() {
  # base command
  base="{{.ID}}\t{{.RunningFor}}\t{{.Status}}\t{{.Ports}}"
  end="\t{{.Names}}"
  extra=""

# if the first param is help, then shows the menu and exit
  if [[ "$1" == "help" ]]; then
    echo "Available attributes for dls (columns you can add):"
    echo "  networks   → Networks the container is connected to"
    echo "  image      → Container image"
    echo "  command    → Command used to start the container"
    echo "  time       → How long the container has been running"
    echo "  size       → Container size (requires --size)"
    echo "  mounts     → Volumes / mounts"
    echo "  labels     → Labels attached to the container"
    echo "  all        → Show all containers (docker container ls -a)"
    echo "  help       → Show this help message"

    return
  fi

  # build columns dinamically
  for arg in "$@"; do
    key=$(echo "$arg" | tr '[:upper:]' '[:lower:]')
    case "$key" in
      networks)
        extra="$extra\t{{.Networks}}"
        ;;
      image)
        extra="$extra\t{{.Image}}"
        ;;
      command)
        extra="$extra\t{{.Command}}"
        ;;
      time)
        extra="$extra\t{{.CreatedAt}}"
        ;;
      size)
        extra="$extra\t{{.Size}}"
        ;;
      mounts)
        extra="$extra\t{{.Mounts}}"
        ;;
      labels)
        extra="$extra\t{{.Labels}}"
        ;;
      all)
        opts="-a"
        ;;
      *)
        if [[ "$key" != "help" ]]; then
          echo "⚠️ Unknown parameter: $arg"
        fi
        ;;
    esac
  done

  docker ps $opts --format "table $base$extra$end"
}

# autocomplete options for 'dls'
_dls_completions() {
    local cur prev opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # list of available columns
    opts="networks image command time size mounts labels all help"

    # Filter options that match what you've already entered
    COMPREPLY=( $(compgen -W "$opts" -- "$cur") )

    return 0
}

# Register completion for 'dls'
complete -F _dls_completions dls

#----------------------------------------------------------------------------------
# filter some attributes from docker inspect with autocompletition
#----------------------------------------------------------------------------------

function dfilter() {
  filter="$1"
  container="$2"

  if [[ -z "$filter" || -z "$container" ]]; then
    echo "Usage: dinspect {mount|volume|network|labels|ip|ports|env|state|health|host|config} <container>"
    return 1
  fi

  case "$filter" in
    mount|mounts)
      docker inspect --format '{{json .Mounts}}' "$container" | jq
      ;;
    volume|volumes|vol)
      docker inspect --format '{{printf "%s" (slice .Name 1)}}: {{range .Mounts}}{{if eq .Type "volume"}}{{.Name}} {{end}}{{end}}' $(docker ps -a -q) | while IFS= read -r line;
      do [[ "${line%%:*}" == "$container" ]] && echo -e "\033[1;32m${line}\033[0m" || echo "$line"; done
      ;;
    network|net|networks)
      docker inspect --format '{{json .NetworkSettings.Networks}}' "$container" | jq
      ;;
    ip|ipaddress)
      docker inspect --format '{{.NetworkSettings.IPAddress}}' "$container"
      ;;
    ports|port)
      docker inspect --format '{{json .NetworkSettings.Ports}}' "$container" | jq
      ;;
    labels|label)
      docker inspect --format '{{json .Config.Labels}}' "$container" | jq
      ;;
    env)
      docker inspect --format '{{json .Config.Env}}' "$container" | jq
      ;;
    state)
      docker inspect --format '{{json .State}}' "$container" | jq
      ;;
    health)
      docker inspect --format '{{json .State.Health}}' "$container" | jq
      ;;
    host|hostconfig)
      docker inspect --format '{{json .HostConfig}}' "$container" | jq
      ;;
    config)
      docker inspect --format '{{json .Config}}' "$container" | jq
      ;;
    *)
      echo "Unknown filter: '$filter'"
      echo "Usage: dinspect {mount|volume|network|labels|ip|ports|env|state|health|host|config} <container>"
      return 1
      ;;
  esac
}

_dfilter() {
  _arguments -C \
    '1:filter:(mount volume network ip ports labels env state health host config)' \
    '2:container name:->containers' && return 0

  case $state in
    containers)
      _values 'containers' ${(f)"$(docker ps --format '{{.Names}}')"}
      ;;
  esac
}

# Register completion for dfilter
compdef _dfilter dfilter


